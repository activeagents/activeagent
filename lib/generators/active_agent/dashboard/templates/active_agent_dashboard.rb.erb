  # Basic auth:
  #   config.authentication_method = ->(controller) {
  #     controller.authenticate_or_request_with_http_basic do |username, password|
  #       username == "admin" && password == Rails.application.credentials.dashboard_password
  #     end
  #   }
  #
  # Devise:
